rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is admin
    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper function to check if user is editor
    function isEditor() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'editor';
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Users collection - only admins can modify roles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin() || 
                   (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])) ||
                   (isOwner(userId) && 
                    request.resource.data.role == 'admin' && 
                    (!exists(/databases/$(database)/documents/config/system) || get(/databases/$(database)/documents/config/system).data.hasAdmin != true));
      allow delete: if isAdmin();
    }
    
    // Deliveries collection
    match /deliveries/{deliveryId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() || isEditor();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Interlogic collection
    match /interlogic/{recordId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() || isEditor();
      allow delete: if isAdmin();
    }
    
    // Clientes collection
    match /clientes/{clienteId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() || isEditor();
      allow update: if isAdmin() || isEditor();
      allow delete: if isAdmin();
    }
    
    // KPI Evaluations collection
    match /kpiEvaluations/{evalId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() || isEditor();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Config collection - for system settings
    match /config/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // User Registry - for username-based authentication
    match /user_registry/{username} {
      allow read: if true; // Allow unauthenticated read for login
      allow write: if isAdmin();
    }

    // Empleados collection
    match /empleados/{empId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() || isEditor();
      allow delete: if isAdmin();
    }

    // Asistencia collection
    match /asistencia/{periodId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() || isEditor();
      allow delete: if isAdmin();
    }

    // Problemas collection
    match /problemas/{problemaId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() || isEditor();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Notas de Crédito collection
    match /notasCredito/{ncId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() || isEditor();
      allow delete: if isAdmin();
    }

    // Cobros collection (Cobranza)
    match /cobros/{cobroId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() || isEditor();
      allow delete: if isAdmin();
    }

    // Gestiones collection (Cobranza)
    match /gestiones/{gestionId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() || isEditor();
      allow delete: if isAdmin();
    }

    // Ajustes collection (Cobranza)
    match /ajustes/{ajusteId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() || isEditor();
      allow delete: if isAdmin();
    }

    // Rutas collection
    match /rutas/{rutaId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() || isEditor();
      allow delete: if isAdmin();
    }

    // Repartidores collection
    match /repartidores/{repartidorId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() || isEditor();
      allow delete: if isAdmin();
    }

    // Ruta Entregas collection
    match /rutaEntregas/{entregaId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() || isEditor();
      allow delete: if isAdmin();
    }

    // Liquidaciones collection
    match /liquidaciones/{liquidacionId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() || isEditor();
      allow delete: if isAdmin();
    }

    // Vehiculos collection (Flota)
    match /vehiculos/{vehiculoId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() || isEditor();
      allow delete: if isAdmin();
    }

    // Mantenimientos collection
    match /mantenimientos/{mantenimientoId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() || isEditor();
      allow delete: if isAdmin();
    }

    // Ordenes de Trabajo collection
    match /ordenesTrabajo/{ordenId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() || isEditor();
      allow delete: if isAdmin();
    }

    // Proveedores (Talleres/Mecanicos) collection
    match /proveedores/{proveedorId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() || isEditor();
      allow delete: if isAdmin();
    }
  }
}
