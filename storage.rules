rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper functions for role checks (read from Firestore users collection)
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
             firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isEditor() {
      return isAuthenticated() &&
             firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'editor';
    }

    // Reglas para entregas (existentes)
    match /deliveries/{imageId} {
      allow read: if isAuthenticated();
      allow write: if (isAdmin() || isEditor())
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }


    // Reglas para asistencia
    match /asistencia/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if (isAdmin() || isEditor())
                   && request.resource.size < 10 * 1024 * 1024;
    }

    // Reglas para problemas
    // Cualquier usuario autenticado puede subir imagenes de soporte de
    // sus problemas. El doc de Firestore correspondiente exige rol
    // admin/editor para crear, pero los editores en campo necesitan poder
    // adjuntar evidencia fotografica sin friccion.
    // Nota: Aceptamos contentType null porque algunos navegadores/moviles
    // (especialmente iOS con HEIC) no envian el MIME type, aunque el
    // codigo JS fuerza un contentType via metadata en el upload.
    match /problemas/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated()
                   && request.resource.size < 5 * 1024 * 1024
                   && (request.resource.contentType == null || request.resource.contentType.matches('image/.*'));
    }

    // Reglas para fotos de vehículos
    match /vehiculos/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated()
                   && request.resource.size < 10 * 1024 * 1024;
    }
  }
}
